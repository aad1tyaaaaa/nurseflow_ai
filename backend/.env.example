# NurseFlow AI Backend Configuration
# Copy this file to .env and update values for your environment

# Application
APP_NAME=NurseFlow AI
APP_VERSION=1.0.0
DEBUG=True
API_V1_PREFIX=/api/v1

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nurseflow_ai
DATABASE_ECHO=False

# Security — CHANGE THIS IN PRODUCTION
SECRET_KEY=change-this-to-a-secure-random-string-at-least-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Redis
REDIS_URL=redis://localhost:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_VITALS_TOPIC=patient-vitals
KAFKA_ALERTS_TOPIC=clinical-alerts

# FHIR Integration (EHR)
# FHIR_BASE_URL=https://your-ehr-system/fhir/r4
# FHIR_CLIENT_ID=
# FHIR_CLIENT_SECRET=

# AI Models
# SBAR_MODEL_PATH=./models/sbar
# FALL_RISK_MODEL_PATH=./models/fall_risk
# NLP_MODEL_PATH=./models/nlp

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
