# NurseFlow AI Backend Configuration
APP_NAME=NurseFlow AI
APP_VERSION=1.0.0
DEBUG=True
API_V1_PREFIX=/api/v1

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:Omkar%402410@localhost:5432/nurseflow_ai
DATABASE_ECHO=False

# Security
SECRET_KEY=change-this-to-a-secure-random-string-at-least-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Redis
REDIS_URL=redis://localhost:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_VITALS_TOPIC=patient-vitals
KAFKA_ALERTS_TOPIC=clinical-alerts
